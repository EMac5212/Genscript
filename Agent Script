<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Student Dashboard</title>

<style>
body{
  font-family:Arial,sans-serif;
  background:#f4f6f9;
  margin:0;
  padding:20px;
}

.header{
  background:#123b66;
  color:white;
  padding:20px;
  border-radius:10px;
  margin-bottom:20px;
}

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:15px;
}

.card{
  background:white;
  padding:15px;
  border-radius:10px;
  box-shadow:0 2px 6px rgba(0,0,0,.1);
}

.label{
  font-size:12px;
  color:#666;
  margin-bottom:5px;
}

.value{
  font-size:18px;
  font-weight:bold;
}

.badge{
  display:inline-block;
  padding:8px 14px;
  border-radius:20px;
  background:#0f9d58;
  color:white;
}
</style>
</head>

<body>

<div class="header">
  <h1 id="institutionName">North State University</h1>
  <p>Student Dashboard</p>
</div>

<div class="grid">

  <div class="card">
    <div class="label">Student Name</div>
    <div class="value" id="studentName"></div>
  </div>

  <div class="card">
    <div class="label">Student ID</div>
    <div class="value" id="studentId"></div>
  </div>

  <div class="card">
    <div class="label">Program</div>
    <div class="value" id="program"></div>
  </div>

  <div class="card">
    <div class="label">Enrollment Status</div>
    <div class="value">
      <span class="badge" id="enrollmentStatus"></span>
    </div>
  </div>

  <div class="card">
    <div class="label">Outstanding Balance</div>
    <div class="value" id="outstandingBalance"></div>
  </div>

  <div class="card">
    <div class="label">Last Payment Date</div>
    <div class="value" id="lastPaymentDate"></div>
  </div>

  <div class="card">
    <div class="label">Financial Aid Status</div>
    <div class="value" id="financialAidStatus"></div>
  </div>

  <div class="card">
    <div class="label">Advisor</div>
    <div class="value" id="advisorName"></div>
  </div>

  <div class="card" style="grid-column:1/-1;">
    <div class="label">Notes</div>
    <div class="value" id="notes"></div>
  </div>

</div>

<script>

const params = new URLSearchParams(window.location.search);

function getParam(name, fallback){
  return params.get(name) || fallback;
}

document.getElementById("studentName").innerText =
  getParam("studentName","Ava Johnson");

document.getElementById("studentId").innerText =
  getParam("studentId","S-100245");

document.getElementById("program").innerText =
  getParam("program","Computer Science");

document.getElementById("enrollmentStatus").innerText =
  getParam("enrollmentStatus","Active");

document.getElementById("outstandingBalance").innerText =
  getParam("outstandingBalance","$1250");

document.getElementById("lastPaymentDate").innerText =
  getParam("lastPaymentDate","2026-04-18");

document.getElementById("financialAidStatus").innerText =
  getParam("financialAidStatus","Eligible");

document.getElementById("advisorName").innerText =
  getParam("advisorName","Jordan Lee");

document.getElementById("notes").innerText =
  getParam("notes","No notes available.");

</script>

</body>
</html>
